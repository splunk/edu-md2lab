{
    "$id": "https://education.splunk.com/schemas/edu-md2lab/manifest.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "edu-md2lab Lab Guide Manifest",
    "description": "Configuration for converting Markdown lab guides to PDF",
    "type": "object",
    "required": ["metadata"],
    "properties": {
        "metadata": {
            "type": "object",
            "required": ["courseId", "courseTitle"],
            "properties": {
                "courseId": {
                    "type": "string",
                    "description": "Course identifier (e.g., 'splunk-course', '1234')"
                },
                "courseTitle": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Full course title"
                },
                "version": {
                    "type": "string",
                    "description": "Course version (e.g., '1.0.0', '9.4')"
                },
                "format": {
                    "type": "string",
                    "description": "Course delivery format (e.g., 'Instructor-led training with labs')"
                },
                "duration": {
                    "type": "string",
                    "description": "Course duration (e.g., '9 hrs.', '2 days')"
                },
                "audience": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1,
                    "description": "Target audience roles"
                },
                "ga": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                    "description": "General availability date (YYYY-MM-DD)"
                },
                "updated": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                    "description": "Last update date (YYYY-MM-DD)"
                }
            },
            "additionalProperties": true
        },
        "input": {
            "type": "object",
            "properties": {
                "labGuides": {
                    "type": "string",
                    "description": "Path to lab guides directory (default: ./lab-guides)"
                }
            },
            "additionalProperties": true
        },
        "output": {
            "type": "object",
            "properties": {
                "destination": {
                    "type": "string",
                    "description": "Output directory path (default: ./dist)"
                },
                "theme": {
                    "type": "string",
                    "description": "Theme name (default: splunk-edu)"
                }
            },
            "additionalProperties": true
        },
        "plugins": {
            "type": "array",
            "items": {
                "oneOf": [
                    { "type": "string" },
                    {
                        "type": "object",
                        "required": ["name"],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Plugin name (must match directory in plugins/)"
                            },
                            "translations": {
                                "type": "object",
                                "description": "Key-value pairs for translation overrides",
                                "additionalProperties": { "type": "string" }
                            }
                        },
                        "additionalProperties": false
                    }
                ]
            },
            "description": "Plugins to load for processing"
        }
    },
    "additionalProperties": true
}
